# Template de variáveis de ambiente do JEMPO.
# Copie para .env e preencha com suas chaves reais:  cp .env.example .env
# O .env é ignorado pelo git (ver .gitignore) e NUNCA deve ser commitado.

# NewsAPI - https://newsapi.org/register
# Plano free: 100 req/dia, cobre apenas os últimos 30 dias.
NEWS_API_KEY=your_newsapi_key_here

# FRED API - https://fred.stlouisfed.org/docs/api/api_key.html
# Opcional, usado apenas como fallback do BCB SGS.
FRED_API_KEY=your_fred_api_key_here

# Anthropic Claude API - https://console.anthropic.com
# Necessário para o agente ECON (ainda não implementado).
ANTHROPIC_API_KEY=

# Fontes que NÃO precisam de chave:
# - GDELT (endpoint público, em agents/sources/gdelt.py)
# - BCB SGS (endpoint público, em agents/journal.py)
# - CVM (downloads públicos, em agents/sources/cvm.py)
# - yfinance (biblioteca Python que consome dados públicos)
